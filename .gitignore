# ============================================
/dist
/tmp
/out-tsc
/bazel-out
*.js
!*.config.js
*.js.map
*.ngfactory.ts
*.ngstyle.ts

# ============================================
# Node / Package managers
# ============================================
/node_modules
npm-debug.log
yarn-error.log
yarn.lock
package-lock.json
pnpm-lock.yaml
.pnpm-debug.log

# ============================================
# IDEs and editors
# ============================================
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project
.netbeans/
.jshintrc

# ============================================
