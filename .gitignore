# ============================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*
.vs-code-remote

# ============================================
# WebStorm
# ============================================
.idea/workspace.xml
.idea/tasks.xml
.idea/dictionaries
.idea/inspectionProfiles

# ============================================
